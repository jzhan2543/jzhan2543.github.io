---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Experience from "../components/Experience.astro";
import Work from "../components/Work.astro";
import Education from "../components/Education.astro";
import Contact from "../components/Contact.astro";
import { experience } from "../data/experience";
import { work } from "../data/work";
import { education } from "../data/education";
---

<Base>
  <Header />
  <main id="main">
    <Hero
      word="reason"
      tagline="AI Engineer based in NYC"
      meta="EST. 2021 · NEW YORK"
      intro="I'm an AI engineer at American Express. I build production ML systems — entity matching, document understanding, agent workflows. Before that: CS at Georgia Tech, MS in Data Science at Illinois."
    />
    <Experience items={experience} />
    <Work items={work} />
    <Education items={education} />
    <Contact />
  </main>
</Base>
