---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Work from "../components/Work.astro";
import { work } from "../data/work";
---

<Base>
  <Header />
  <Hero
    word="reason"
    tagline="AI Engineer based in NYC"
    meta="EST. 2021 · NEW YORK"
    intro="I'm an AI engineer at American Express. I build production ML systems — entity matching, document understanding, agent workflows. Before that: CS at Georgia Tech, MS in Data Science at Illinois."
  />
  <Work items={work} />
</Base>
