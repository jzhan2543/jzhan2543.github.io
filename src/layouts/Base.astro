---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Jefferson Zhan — AI Engineer based in NYC",
  description = "Personal site of Jefferson Zhan, AI Engineer based in NYC.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      rel="preload"
      href="/fonts/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <div class="mx-auto max-w-5xl px-6 sm:px-10">
      <slot />
    </div>
  </body>
</html>
