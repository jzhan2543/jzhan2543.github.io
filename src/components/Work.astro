---
import type { WorkItem } from "../data/work";

interface Props {
  items: WorkItem[];
}

const { items } = Astro.props;
---

<section id="work" class="pt-12 pb-24 sm:pt-20 sm:pb-40">
  <header class="border-b border-rule pb-3 mb-10">
    <h2 class="text-body lowercase">work</h2>
  </header>

  <ul>
    {
      items.map((item) => (
        <li class="grid grid-cols-1 gap-y-2 border-t border-rule py-6 first:border-t-0 sm:grid-cols-[100px_1fr_auto] sm:gap-x-10 sm:gap-y-0">
          <time class="text-meta text-muted uppercase">{item.date}</time>
          <div>
            <h3 class="text-body">{item.title}</h3>
            <p class="text-body text-muted mt-1">{item.description}</p>
          </div>
          {item.href ? (
            <a
              href={item.href}
              class="text-meta text-accent uppercase no-underline whitespace-nowrap"
              target="_blank"
              rel="noopener noreferrer"
            >
              SEE DETAILS →
            </a>
          ) : (
            <span aria-hidden="true" />
          )}
        </li>
      ))
    }
  </ul>
</section>
