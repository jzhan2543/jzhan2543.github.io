---
import type { ExperienceItem } from "../data/experience";

interface Props {
  items: ExperienceItem[];
}

const { items } = Astro.props;
---

<section id="experience" class="py-12 sm:py-16">
  <header class="border-b border-rule pb-6">
    <h2 class="text-h2 lowercase">experience</h2>
  </header>

  <ul>
    {
      items.map((item) => (
        <li class="grid grid-cols-1 gap-y-2 border-t border-rule py-6 first:border-t-0 sm:grid-cols-[100px_1fr_auto] sm:gap-x-10 sm:gap-y-0">
          <time class="text-meta text-muted uppercase">{item.date}</time>
          <div>
            <h3 class="text-body">{item.company}</h3>
            <p class="text-body text-muted mt-1">{item.role}</p>
          </div>
          <span class="text-meta text-muted uppercase whitespace-nowrap">{item.location}</span>
        </li>
      ))
    }
  </ul>
</section>
